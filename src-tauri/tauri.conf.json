{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kütral",
  "version": "26.5.0",
  "identifier": "app.kutral",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Kütral",
        "width": 1280,
        "height": 800,
        "maximized": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPCACHE/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "nsis", "msi"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI5RTJDNDcxOTQ0NTNDMUYKUldRZlBFV1VjY1RpS2VmTDNJZm1LVXRQY0NYakF4WTRZRUVCMGxGeHlETWhwU1NxaCt2MG92YngK",
      "endpoints": [
        "https://github.com/Debaq/kutral/releases/latest/download/latest.json"
      ]
    }
  }
}
